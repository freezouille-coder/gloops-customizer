    "birthing": {
        "_doc": "Gloops are NOT hatched from eggs. They GROW from the soil in the Birthing Ground. The health of the island biases which breed germinates.",
        "building": "birthing_ground",
        "base_interval_sec": 120,
        "rarity_weights_by_corruption": {
