    "merging": {
        "_doc": "Pyramidal merging: 3 same-tier → 1 upper-tier. For Epic→Legendary the recipe determines WHICH demon is summoned. Mixed recipes fall back to random.",
        "rules": {
            "common_to_uncommon":   { "input": 3, "tier_in": "common",    "tier_out": "uncommon" },
            "uncommon_to_rare":     { "input": 3, "tier_in": "uncommon",  "tier_out": "rare" },
            "rare_to_epic":         { "input": 3, "tier_in": "rare",      "tier_out": "epic" },
            "epic_to_legendary":    { "input": 3, "tier_in": "epic",      "tier_out": "legendary" }
        },
        "epic_to_legendary_recipes": [
            {
                "name": "Sickness Loop Summon",
                "input": ["corpo_suit", "corpo_suit", "corpo_suit"],
                "output": "demon_toxitamol",
                "corruption": 15
            },
            {
                "name": "Content Machine",
                "input": ["corpo_suit", "corpo_suit", "golden_mule"],
                "output": "demon_netflux",
                "corruption": 12
            },
            {
                "name": "Feed Algorithm",
                "input": ["corpo_suit", "golden_mule", "golden_mule"],
                "output": "demon_twitix",
                "corruption": 12
            },
            {
                "name": "Vegas Pact",
                "input": ["corpo_suit", "corpo_suit", "street_pirate"],
                "output": "demon_gamblingbling",
                "corruption": 14,
                "note": "The pirate sells his soul to the corpo side."
            },
            {
                "name": "Fermentation Deal",
                "input": ["corpo_suit", "street_pirate", "street_pirate"],
                "output": "demon_alcolard",
                "corruption": 10
            },
            {
                "name": "Smoke Ritual",
                "input": ["street_pirate", "street_pirate", "street_pirate"],
                "output": "demon_nicotic",
                "corruption": 8,
                "note": "Three pirates share a pipe. Something answers."
            },
            {
                "name": "Candy Factory Overload",
                "input": ["green_warden", "corpo_suit", "corpo_suit"],
                "output": "demon_sugar",
                "corruption": 18,
                "note": "The druid's crops are sold to the factory. Irreversible."
            },
            {
                "name": "Paywall Intimacy",
                "input": ["corpo_suit", "corpo_suit", "only_option"],
                "output": "only_demon",
                "corruption": 16,
                "note": "Wildcard: any third Epic works."
            },
            {
                "name": "Blessed Ascension",
                "input": ["shaman", "shaman", "shaman"],
                "output": "saint_gloop",
                "corruption": -40,
                "note": "Three shamans in perfect harmony. Requires corruption < 20 to trigger. The secret Healfy legendary."
            },
            {
                "name": "Warden Coven",
                "input": ["green_warden", "green_warden", "shaman"],
                "output": "saint_gloop",
                "corruption": -30,
                "note": "Alternative Saint Gloop recipe."
            }
        ]
    },

